#!/bin/sh

DEVICE_NAME=aesdchar
MODULE_DIR=/lib/modules/$(uname -r)/extra

case "$1" in
    start)
        echo "Loading ${DEVICE_NAME} module..."

        insmod ${MODULE_DIR}/aesdchar.ko

        MAJOR=$(awk -v dev="$DEVICE_NAME" '$2==dev {print $1}' /proc/devices)
        if [ -z "$MAJOR" ]; then
            echo "Failed to find major number for ${DEVICE_NAME}"
            exit 1
        fi

        rm -f /dev/${DEVICE_NAME}
        mknod /dev/${DEVICE_NAME} c ${MAJOR} 0
        chmod 666 /dev/${DEVICE_NAME}
        ;;

    stop)
        echo "Unloading ${DEVICE_NAME} module..."

        rm -f /dev/${DEVICE_NAME}
        rmmod ${DEVICE_NAME}
        ;;
    
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac

exit 0
